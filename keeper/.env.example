# EquiFlow keeper — copy to keeper/.env and fill in.

# Robinhood Chain testnet RPC + chain id
RBN_RPC_URL=https://...
CHAIN_ID=46630

# Keeper key (must be an authorized keeper: adapter.setKeeper(addr, true))
KEEPER_PK=0x...

# Adapter resolution — EITHER set the registry (preferred) ...
ADAPTER_REGISTRY=0x...
# ... OR pin each adapter explicitly (overrides the registry):
# ADAPTER_TSLA=0x...
# ADAPTER_AMZN=0x...
# ADAPTER_PLTR=0x...
# ADAPTER_NFLX=0x...
# ADAPTER_AMD=0x...

# Pyth Hermes (default is the public endpoint)
HERMES_URL=https://hermes.pyth.network

# Cadence / thresholds (defaults shown; must match the on-chain config)
TICK_SEC=60            # loop interval
HEARTBEAT_SEC=300      # force a push at least this often (<< staleAfter 1h)
DEV_TRIGGER_BPS=50     # push when deviation >= 0.5%
DEVIATION_CAP_BPS=500  # adapter maxDeviationBps (5%) — do not exceed per update
MAX_AGE_SEC=3600       # adapter maxAge / vault staleAfter (1h)
